# NEXT — env template. Copy to .env.local in each app/service that needs it.
# Real secrets come from Vault via External Secrets; this file is for non-secret defaults.

# ----- Common -----
NEXT_ENV=dev
VERSION=0.1.0-dev
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ----- Data tier (local docker compose) -----
# Postgres + Redis are shifted off the default ports to avoid collisions with
# any native postgres / redis service already listening on 5432 / 6379.
POSTGRES_URL=postgres://next:next@localhost:5433/next?sslmode=disable
REDIS_URL=redis://localhost:6380
KAFKA_BROKERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081
CLICKHOUSE_URL=http://localhost:8123
OPENSEARCH_URL=http://localhost:9200
QDRANT_URL=http://localhost:6334

# ----- Web (apps/web) -----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql

# ----- Mobile (apps/mobile) -----
EXPO_PUBLIC_API_URL=http://localhost:4000

# ----- Auth -----
JWT_ISSUER=https://auth.next.local
JWT_AUDIENCE=next-api
JWKS_URI=http://localhost:4000/.well-known/jwks.json

# ----- AWS (used only by infra and integration tests) -----
AWS_REGION=us-east-1
AWS_PROFILE=next-dev
