{
  "name": "@next/events",
  "version": "0.1.0",
  "private": true,
  "description": "Event schemas, producer, and consumer helpers for the NEXT Kafka bus.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./producer": "./src/producer.ts",
    "./consumer": "./src/consumer.ts",
    "./topics": "./src/topics.ts",
    "./contracts": "./src/contracts/index.ts",
    "./contracts/envelope": "./src/contracts/envelope.ts",
    "./contracts/fixtures": "./src/contracts/fixtures.ts",
    "./contracts/schema-registry": "./src/contracts/schema-registry.ts",
    "./schemas": "./schemas/index.ts"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. tests/backend/events",
    "test:unit": "vitest run --root ../.. tests/backend/events",
    "codegen": "cd ../.. && buf generate"
  },
  "dependencies": {
    "@bufbuild/protobuf": "catalog:",
    "@opentelemetry/api": "catalog:",
    "kafkajs": "^2.2.4",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@next/config": "workspace:*",
    "@next/logger": "workspace:*",
    "@next/types": "workspace:*",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
