{
  "name": "@next/api-client",
  "version": "0.1.0",
  "private": true,
  "description": "Generated GraphQL and gRPC clients consumed by all apps. Codegen target.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./graphql": "./src/graphql.ts",
    "./grpc": "./src/grpc.ts",
    "./__generated__/*": "./src/__generated__/*"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "codegen": "graphql-codegen --config codegen.ts && buf generate"
  },
  "dependencies": {
    "@apollo/client": "catalog:",
    "@bufbuild/protobuf": "catalog:",
    "graphql": "catalog:"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/client-preset": "^4.5.0",
    "@next/config": "workspace:*",
    "typescript": "catalog:"
  }
}
