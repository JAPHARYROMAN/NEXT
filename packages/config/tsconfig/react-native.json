{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "NEXT — React Native / Expo configuration",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["esnext"],
    "jsx": "react-native",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "types": ["node", "react-native"]
  }
}
