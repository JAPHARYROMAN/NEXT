{
  "name": "@next/config",
  "version": "0.1.0",
  "private": true,
  "description": "Shared eslint, tsconfig, tailwind, prettier, and vitest configs for the NEXT monorepo.",
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "eslint/",
    "tsconfig/",
    "tailwind/",
    "vitest/",
    "prettier/"
  ],
  "exports": {
    "./eslint/base": "./eslint/base.mjs",
    "./eslint/react": "./eslint/react.mjs",
    "./eslint/next": "./eslint/next.mjs",
    "./eslint/node": "./eslint/node.mjs",
    "./tsconfig/base": "./tsconfig/base.json",
    "./tsconfig/library": "./tsconfig/library.json",
    "./tsconfig/next": "./tsconfig/next.json",
    "./tsconfig/react-native": "./tsconfig/react-native.json",
    "./tailwind/base": "./tailwind/base.cjs",
    "./vitest/base": "./vitest/base.ts",
    "./vitest/react": "./vitest/react.ts"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
