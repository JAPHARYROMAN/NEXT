root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

[*.{md,mdx}]
trim_trailing_whitespace = false
max_line_length = off

[*.{go,Makefile}]
indent_style = tab
indent_size = 4

[*.{py,pyi}]
indent_size = 4
max_line_length = 100

[*.{rs,toml}]
indent_size = 4

[*.{yaml,yml}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2

[*.proto]
indent_size = 2

[*.{tf,tfvars,hcl}]
indent_size = 2
