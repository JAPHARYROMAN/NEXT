# =====================================================================
# NEXT — root .gitignore
# =====================================================================

# ----- Node / JS / TS -----
node_modules/
.pnp.*
.yarn/
.npm/
.pnpm-store/
.pnpm-debug.log*
*.tsbuildinfo
.swc/
dist/
build/
out/
.next/
.nuxt/
.output/
.vercel/
.turbo/
storybook-static/
.cache/
.parcel-cache/
.docusaurus/

# ----- Test / Coverage -----
coverage/
*.lcov
.nyc_output/
playwright-report/
test-results/
.vitest/
junit.xml

# ----- Generated code -----
**/__generated__/
**/generated/
**/gen/
# But keep the module boundary files for /gen/go so the Go workspace resolves.
# Generated .pb.go files are regenerated by `buf generate` / `task codegen`.
!gen/go/go.mod
!gen/go/go.sum
!**/src/**/generated/.gitkeep

# ----- Buf v3 module cache (created by `buf` CLI on Windows/WSL) -----
# Contents: commitlocks/, commits/, modulelocks/, modules/, plugins/,
# policies/, wellknowntypes/. Local cache only — never commit.
v3/

# ----- Claude Code session state -----
.claude/

# ----- Logs -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ----- Env / Secrets -----
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.crt
*.p12
secrets/
.secrets/
!secrets/.gitkeep

# ----- IDE / OS -----
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.iml
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ----- Go -----
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
vendor/

# ----- Rust -----
target/
**/*.rs.bk
Cargo.lock.bak

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
*.egg-info/
*.egg
pip-log.txt
pip-delete-this-directory.txt
.ipynb_checkpoints
.uv-cache/

# ----- Terraform -----
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
*.tfvars
!terraform.tfvars.example
!*.tfvars.example
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ----- Kubernetes / Helm -----
**/charts/*.tgz
.helm/

# ----- Docker -----
.docker/

# ----- ML / Data -----
*.ckpt
*.pt
*.pth
*.onnx
*.safetensors
*.bin
data/
datasets/
checkpoints/
runs/
mlruns/
wandb/

# ----- Misc -----
*.tar.gz
*.zip
.tmp/
tmp/
.scratch/
scratch/
